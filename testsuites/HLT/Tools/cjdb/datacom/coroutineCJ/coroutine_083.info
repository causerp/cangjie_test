// LEVEL: 2
// DEPENDENCE:  ../../cjdb_test.py ../../basecase/coroutine/
// EXEC: %compiler %cmp_opt -g coroutine/coroutine_21.cj -o coroutine_21%cmp_output
// RUN-EXEC: python3 cjdb_test.py coroutine_083.info coroutine_21 %run_env

test#
cjdb,cjdb --no-use-colors coroutine_21,coroutine_21
b,b 25,coroutine_21.cj:25
AOT r,r,-> 25
b,breakpoint disable,
cjthread,cjthread list,thread #[\s\S]*state = running[\s\S]*coroutine_21.cj:25
cjthread,cjt list --state=0,No cjthreads found with state 'idle'.
cjthread,cjt list --state=1,thread #[\s\S]*state = ready
cjthread,cjt list --state=2,thread #[\s\S]*state = running
cjthread,cjt list --state=3,No cjthreads found with state 'pending'.
cjthread,cjt list --state=4,No cjthreads found with state 'syscall'.
q,quit,

// LEVEL: 2
// DESC: 测试基础场景：当开启--coverage时，不支持开启后端并行
// DEPENDENCE: gen_src.py check.py
// EXEC: %python gen_src.py
// 开启APC，同时开启--coverage
// EXEC-PIPE: %compiler %cmp_opt --dump-ir main.cj --coverage --apc=5 -o %output 2>&1 | compare %f
// RUN-EXEC: %run %run_opt %output %run_args

// 当前，目标平台为Windows或MacOS或iOS时，不支持开启后端并行
// (target_win) ASSERT: scan '--apc' is not supported when targeting windows.
// (target_mac) ASSERT: scan '--apc' is not supported when targeting darwin.
// (target_ios | target_ios_simulator) ASSERT: scan '--apc' is not supported when targeting ios.
// (target_win | target_mac) EXEC: %python check.py --dir_path "%n"_IR/3_GenTypeInfos --expected_count 1
// (target_ios | target_ios_simulator) EXEC: %python check.py --dir_path libcangjie_main_IR/3_GenTypeInfos --expected_count 1

// 目标平台为Linux或OHOS或Android时，支持开启后端并行，但由于开启--coverage，导致APC无效
// (target_linux | target_ohos | target_android) EXEC: %python check.py --dir_path "%n"_IR/3_GenTypeInfos --expected_count 1
// (target_linux | target_ohos | target_android) ASSERT: scan

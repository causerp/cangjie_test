package cjworld

import objc.lang.*

@ObjCImpl
public class A <: Base & BaseProto {
    public A() {
    }

    @ForeignName["test"]
    public func test(): Unit {
        println("A.test() called")
    }

    public func identify(): Unit {
        println("A.identify() called")
    }
}

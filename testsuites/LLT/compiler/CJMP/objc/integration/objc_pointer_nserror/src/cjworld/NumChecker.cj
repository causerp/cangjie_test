package cjworld

import objc.lang.*

@ObjCMirror
public open class NumChecker <: NSObject {
    public init()
    @ForeignName["checkWithNumber:andError:"]
    public open func checkWithNumberAndError(num: ?NSNumber, error: ObjCPointer<?NSError>): ?NSNumber
}